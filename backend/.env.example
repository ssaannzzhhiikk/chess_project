# Endgame backend environment
# Copy to backend/.env for local development.

APP_NAME=Endgame API
APP_ENV=development

# Required in every environment.
# The app accepts JWT_SECRET_KEY and still supports legacy JWT_SECRET.
JWT_SECRET_KEY=change-me-development-only
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5433/chess_app

# Optional but strongly recommended for stable multiplayer.
REDIS_URL=redis://localhost:6379/0

# Optional.
OPENAI_API_KEY=

# Comma-separated frontend origins allowed to call the API.
CORS_ORIGINS=http://localhost:3000
